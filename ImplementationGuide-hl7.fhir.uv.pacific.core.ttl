         fhir:link <https://healthinfoservices.net/fiji-pacific-ig/Organization/PacificHospitalExample> ;
         fhir:reference [ fhir:v "Organization/PacificHospitalExample" ]
       ] ;
       fhir:name [ fhir:v "Pacific Hospital Example Fiji Divisional Hospital" ] ;
       fhir:description [ fhir:v "Example Pacific hospital organization in Fiji.\nIncludes organizational identifier, contact information, and address." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v true
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "StructureDefinition:complex-type"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <https://healthinfoservices.net/fiji-pacific-ig/StructureDefinition/pacific-humanname> ;
         fhir:reference [ fhir:v "StructureDefinition/pacific-humanname" ]
       ] ;
       fhir:name [ fhir:v "Pacific HumanName" ] ;
       fhir:description [ fhir:v "A HumanName profile designed for South Pacific jurisdictions.\n\nIn the South Pacific, naming conventions are diverse and may not align with Western norms. This profile accommodates a range of naming practices used in the South Pacific including:\n\n- Absence of family names (e.g., in some cultures where individuals may have only given names)\n- Patronymic or Matronymic structures\n- Multiple given names\n- Customary and ceremonial naming\n- Distinction between 'usual' (social) and 'official' (legal) names\n\nAt least one PacificHumanName instance must exist on PacificPatient and PacificPractitioner resources.\nSystems SHALL NOT require both usual and official names.\n\nNote: Clan affiliation is recorded separately from the PacificHumanName.  It issupported as an optional extension of  PacificPatient and PacificPractitioner resources to capture important cultural identity information.\n\n**STATUS**: Proposed - needs further review and consensus from South Pacific stakeholders before finalization." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "StructureDefinition:resource"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <https://healthinfoservices.net/fiji-pacific-ig/StructureDefinition/pacific-observation> ;
         fhir:reference [ fhir:v "StructureDefinition/pacific-observation" ]
       ] ;
       fhir:name [ fhir:v "Pacific Observation" ] ;
       fhir:description [ fhir:v "Profile of Observation as defined for South Pacific." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "StructureDefinition:resource"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <https://healthinfoservices.net/fiji-pacific-ig/StructureDefinition/pacific-patient> ;
         fhir:reference [ fhir:v "StructureDefinition/pacific-patient" ]
       ] ;
       fhir:name [ fhir:v "Pacific Patient" ] ;
       fhir:description [ fhir:v "Base Patient profile for South Pacific jurisdictions.\n\nIntegrates:\n- PacificHumanName\n- Patient-level clan affiliation\n- Guidance for usual vs official name use" ] ;
